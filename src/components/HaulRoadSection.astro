---
import { TrendingUp, ShieldCheck, Zap, BarChart3, Globe } from 'lucide-react';
---

<section id="haul-road-impact" class="py-12 px-6 lg:px-12 bg-transparent relative overflow-hidden">
  <div class="max-w-6xl mx-auto relative">
    {/* Connector Line from Experience */}
    <div class="absolute -top-12 left-12 w-px h-12 bg-gradient-to-b from-primary/30 to-transparent"></div>
    
    <div class="bg-card border border-border/50 rounded-3xl overflow-hidden shadow-2xl">
      <div class="grid lg:grid-cols-2 gap-0 items-stretch">
        
        {/* Content Side */}
        <div class="p-8 lg:p-12 flex flex-col justify-center space-y-6">
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-[10px] font-bold uppercase tracking-widest mb-4">
              <ShieldCheck class="h-3 w-3" />
              Strategic Enterprise Project
            </div>
            <h2 class="text-3xl lg:text-4xl font-black text-foreground leading-tight tracking-tighter mb-4">
              The Haul Road <br />
              <span class="text-primary italic">Optimization Engine</span>
            </h2>
            <p class="text-base text-muted-foreground leading-relaxed">
              Automated undulation and gradient detection system at <span class="text-foreground font-semibold">Tata Steel</span>, optimizing mine transportation through Python-led automation.
            </p>
          </div>

          {/* Impact Metric */}
          <div class="p-5 rounded-xl bg-primary/5 border border-primary/20 flex items-center justify-between group">
            <div>
              <p class="text-[10px] font-bold text-primary uppercase tracking-[0.2em] mb-1">Financial Benefit</p>
              <p class="text-3xl font-black text-foreground">₹1 - 4 <span class="text-lg text-primary">Crore</span></p>
              <p class="text-[10px] text-muted-foreground mt-1">Projected savings over 3 years</p>
            </div>
            <div class="p-3 bg-primary/10 rounded-lg text-primary">
              <TrendingUp class="h-6 w-6" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-2">
              <h4 class="flex items-center gap-2 text-xs font-bold text-foreground">
                <Zap class="h-3 w-3 text-primary" />
                Impact
              </h4>
              <p class="text-[10px] text-muted-foreground leading-relaxed">
                Automated 100% of road health monitoring, reducing manual survey overhead by 240%.
              </p>
            </div>
            <div class="space-y-2">
              <h4 class="flex items-center gap-2 text-xs font-bold text-foreground">
                <Globe class="h-3 w-3 text-primary" />
                Deployment
              </h4>
              <p class="text-[10px] text-muted-foreground leading-relaxed">
                Centrally deployed on <b>GCP</b> for real-time orchestration across mining sectors.
              </p>
            </div>
          </div>

          <div class="flex flex-wrap gap-2 pt-2">
            {["Python", "GCP", "Automation", "Mine Tech"].map(tech => (
              <span class="px-3 py-1 rounded-lg bg-background border border-border text-[9px] font-bold text-muted-foreground uppercase tracking-widest">
                {tech}
              </span>
            ))}
          </div>
        </div>

        {/* Visual Side */}
        <div class="relative min-h-[300px] lg:min-h-full bg-muted">
          <img 
            src="/haul_road_viz.png" 
            alt="Haul Road Analysis Visualization" 
            class="absolute inset-0 w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-700"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-card via-transparent to-transparent hidden lg:block"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-card via-transparent to-transparent lg:hidden"></div>
        </div>

      </div>
    </div>
  </div>
</section>
